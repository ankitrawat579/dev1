<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CheckStatus__c</fullName>
    <externalId>false</externalId>
    <formula>IF(TEXT(Review_Stage__c) = &quot;Shortlisted&quot;, 
    IMAGE(&quot;/img/samples/color_green.gif&quot;, &quot;green&quot;,30, 30), 
    IF(TEXT(Review_Stage__c) = &quot;Rejected&quot;, 
        IMAGE(&quot;/img/samples/color_red.gif&quot;, &quot;red&quot;,30,30), 
        IMAGE(&quot;/img/samples/color_yellow.gif&quot;, &quot;Yellow&quot;,30,30)
    )
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>CheckStatus</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
