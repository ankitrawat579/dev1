<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Interview_Round_Should_Not_Update</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
   NOT(ISNEW()),
   ISCHANGED( Interview_Round__c )
)</errorConditionFormula>
    <errorDisplayField>Interview_Round__c</errorDisplayField>
    <errorMessage>Interview Round field cannot be updated</errorMessage>
</ValidationRule>
