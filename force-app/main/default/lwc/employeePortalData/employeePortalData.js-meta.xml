<?xml version="1.0"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
        <apiVersion>55.0</apiVersion>
        <isExposed>true</isExposed>
        <targets>
            <target>lightning__AppPage</target>
            <target>lightning__HomePage</target>
            <target>lightning__RecordPage</target>
        </targets>
        <targetConfigs>
            <targetConfig targets="lightning__HomePage">
                <property
                        name="dType"
                        label="Type of Data"
                        type="String"
                        default="Employee"
                        required="true"
                />
                <property
                        name="isSingle"
                        label=" Is Single Record"
                        type="Boolean"
                        default="true"
                        required="true"
                />


                <property
                    name="sectionheading"
                    label="Section Heading"
                    type="String"
                    default="Employee Details"
                    required="true"
                />

                <property
                    name="isHoliday"
                    label="Is Holiday Data"
                    type="Boolean"
                    default="true"
                    required="true"
                />

                <property
                    name="orderBy"
                    label="Order By"
                    type="String"
                    default=""
                    required="true"
                />


                <property
                    name="orderType"
                    label="Order Type"
                    type="String"
                    default="ASC"
                    required="true"
                />


                <property
                    name="limit"
                    label="Limits"
                    type="Integer"
                    default="0"
                    required="true"
                />
    
            </targetConfig>
        </targetConfigs>
</LightningComponentBundle>